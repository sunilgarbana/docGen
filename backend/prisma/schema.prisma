generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id          String   @id @default(uuid())
  email       String   @unique
  name        String
  githubToken String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  repos Repo[]
}

model Repo {
  id              String    @id @default(uuid())
  userId          String
  user            User      @relation(fields: [userId], references: [id])
  githubUrl       String
  name            String
  description     String?
  defaultBranch   String    @default("main")
  lastGeneratedAt DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  jobs          DocJob[]
  generatedDocs GeneratedDoc[]
}

model DocJob {
  id           String    @id @default(uuid())
  repoId       String
  repo         Repo      @relation(fields: [repoId], references: [id])
  status       String    @default("PENDING") // PENDING, PROCESSING, DONE, FAILED
  startedAt    DateTime?
  completedAt  DateTime?
  errorMessage String?
  createdAt    DateTime  @default(now())

  generatedDocs GeneratedDoc[]
}

model GeneratedDoc {
  id         String    @id @default(uuid())
  repoId     String
  repo       Repo      @relation(fields: [repoId], references: [id])
  jobId      String
  job        DocJob    @relation(fields: [jobId], references: [id])
  format     String    // MARKDOWN, OPENAPI, DOCSTRING
  content    String
  commitHash String
  createdAt  DateTime  @default(now())
}
